# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# How often to scrape (in minutes). Default: 60
SCRAPE_INTERVAL_MINUTES=60

# Database URL (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite:///./bias_detector.db
